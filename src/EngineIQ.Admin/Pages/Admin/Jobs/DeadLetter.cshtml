@page "/admin/jobs/dead-letter"
@model EngineIQ.Admin.Pages.Admin.Jobs.DeadLetterModel
@{
    ViewData["Title"] = "Dead letter";
}

<h1 class="mb-3">Dead letter & failed jobs</h1>

@if (TempData["Flash"] is string flash)
{
    <div class="alert alert-info">@flash</div>
}

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-warning">@Model.Error</div>
}

<h2 class="h4 mt-4">Failed jobs (PostgreSQL)</h2>
<p class="text-muted">Resets row to Queued and republishes to the main RabbitMQ queue.</p>
<table class="table table-sm table-striped">
    <thead>
    <tr>
        <th>Tenant</th>
        <th>Repository</th>
        <th>PR</th>
        <th>When (UTC)</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var j in Model.FailedDbJobs)
    {
        <tr>
            <td>@j.TenantName</td>
            <td><code>@j.RepositoryFullName</code></td>
            <td>@j.PrNumber</td>
            <td>@j.When.ToString("u")</td>
            <td>
                <form method="post" asp-page-handler="RetryDbJob">
                    <input type="hidden" name="tenantId" value="@j.TenantId" />
                    <input type="hidden" name="jobId" value="@j.JobId" />
                    <button type="submit" class="btn btn-sm btn-primary">Retry</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

<h2 class="h4 mt-4">RabbitMQ DLQ (preview)</h2>
<p class="text-muted">Peek uses BasicGet + nack(requeue); retry drains DLQ and moves one message to the main queue.</p>
<ol class="small">
@for (var i = 0; i < Model.DlqPreviews.Count; i++)
{
    <li class="mb-2">
        <pre class="bg-light p-2">@Model.DlqPreviews[i]</pre>
        <form method="post" asp-page-handler="RetryDlq" class="d-inline">
            <input type="hidden" name="index" value="@i" />
            <button type="submit" class="btn btn-sm btn-warning">Retry #@i</button>
        </form>
    </li>
}
</ol>
