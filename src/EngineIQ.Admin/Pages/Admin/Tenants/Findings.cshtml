@page "/admin/tenants/{id}/findings"
@model EngineIQ.Admin.Pages.Admin.Tenants.FindingsModel
@{
    ViewData["Title"] = $"Findings {Model.TenantId}";
}

<p><a asp-page="/Admin/Tenants/Index">← Tenants</a></p>
<h1 class="mb-3">Findings</h1>
<p class="text-muted">Tenant <code>@Model.TenantId</code> — metadata only (no source).</p>

<table class="table table-sm table-striped">
    <thead>
    <tr>
        <th>When (UTC)</th>
        <th>Severity</th>
        <th>Category</th>
        <th>Source</th>
        <th>File</th>
        <th>Line</th>
        <th>Actioned</th>
        <th>PR merge</th>
        <th>Message</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var f in Model.Findings)
    {
        <tr>
            <td>@f.CreatedAt.ToString("u")</td>
            <td>@f.Severity</td>
            <td>@f.Category</td>
            <td>@f.Source</td>
            <td><code>@f.FilePath</code></td>
            <td>@f.LineNumber</td>
            <td>@f.WasActioned</td>
            <td>@f.PrMergeStatus</td>
            <td>@f.Message</td>
        </tr>
    }
    </tbody>
</table>
