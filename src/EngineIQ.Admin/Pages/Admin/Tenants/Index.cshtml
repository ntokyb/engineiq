@page "/admin/tenants"
@model EngineIQ.Admin.Pages.Admin.Tenants.IndexModel
@{
    ViewData["Title"] = "Tenants";
}

<h1 class="mb-3">Tenants</h1>

<table class="table table-sm table-striped align-middle">
    <thead>
    <tr>
        <th>Name</th>
        <th>Plan</th>
        <th>Status</th>
        <th class="text-end">PRs</th>
        <th>Last active (UTC)</th>
        <th class="text-end">MRR (ZAR)</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var t in Model.Tenants)
    {
        <tr>
            <td><a asp-page="/Admin/Tenants/Findings" asp-route-id="@t.Id">@t.Name</a></td>
            <td>@t.Plan</td>
            <td>@t.Status</td>
            <td class="text-end">@t.PrCount</td>
            <td>@(t.LastActive?.ToString("u") ?? "—")</td>
            <td class="text-end">@t.MrrContributionZar.ToString("N2")</td>
            <td class="text-nowrap">
                @if (t.Status != "Suspended")
                {
                    <form method="post" asp-page-handler="Suspend" asp-route-id="@t.Id" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Suspend</button>
                    </form>
                }
                else
                {
                    <span class="text-muted small">Suspended</span>
                }
                <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#up-@t.Id">Upgrade</button>
            </td>
        </tr>
        <tr class="collapse" id="up-@t.Id">
            <td colspan="7">
                <form method="post" asp-page-handler="Upgrade" asp-route-id="@t.Id" class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label">Plan</label>
                        <input name="plan" class="form-control form-control-sm" value="@t.Plan" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Feature flags (JSON, optional)</label>
                        <input name="featureFlagsJson" class="form-control form-control-sm" placeholder='{"beta_rules":true}' />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary btn-sm">Save</button>
                    </div>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
