@page "/admin/metrics"
@model EngineIQ.Admin.Pages.Admin.MetricsModel
@{
    ViewData["Title"] = "Metrics";
    var m = Model.Metrics;
}

<h1 class="mb-3">Platform metrics (UTC today)</h1>

@if (m is null)
{
    <p>No data.</p>
}
else
{
    <dl class="row">
        <dt class="col-sm-3">PRs reviewed today</dt>
        <dd class="col-sm-9">@m.PrsReviewedToday</dd>
        <dt class="col-sm-3">Avg review latency (ms)</dt>
        <dd class="col-sm-9">@(m.AvgReviewLatencyMsToday?.ToString("N0") ?? "—")</dd>
        <dt class="col-sm-3">Token cost (ZAR) today</dt>
        <dd class="col-sm-9">@m.TokenCostZarToday.ToString("N4")</dd>
        <dt class="col-sm-3">Revenue MRR (ZAR, estimated)</dt>
        <dd class="col-sm-9">@m.RevenueMrrZar.ToString("N2")</dd>
    </dl>
}
