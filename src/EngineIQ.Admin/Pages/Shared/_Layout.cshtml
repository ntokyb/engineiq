<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EngineIQ Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-3">
            <div class="container-fluid">
                <span class="navbar-brand">EngineIQ Admin</span>
                <div class="navbar-nav">
                    <a class="nav-link text-white" asp-page="/Admin/Tenants/Index">Tenants</a>
                    <a class="nav-link text-white" asp-page="/Admin/Metrics">Metrics</a>
                    <a class="nav-link text-white" asp-page="/Admin/Jobs/DeadLetter">Dead letter</a>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4 pb-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
