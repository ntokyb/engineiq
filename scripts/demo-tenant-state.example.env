# Operator-local credentials for Codist "golden four" tenants — NEVER commit real keys.
#
# These personas are permanent integration fixtures (ongoing PRs across Codist repos).
# Copy this file to: scripts/demo-tenant-state.local.env (gitignored).
# Paste tenant_id + api_key once onboarding succeeds; update only if keys rotate intentionally.
#
# ENGINEIQ_API_URL=https://api.engineiq.co.za

# TENANT_MYBILLABLE=
# API_KEY_MYBILLABLE=

# TENANT_THERECORD=
# API_KEY_THERECORD=

# TENANT_SKILLBAY=
# API_KEY_SKILLBAY=

# TENANT_WARROOM=
# API_KEY_WARROOM=

# --- Single-install sanity (internal use only) ---
# GitHub enforces one EngineIQ linkage per installation_id (unique in DB).
# INSTALLATION_ID_NTOKYB_OR_PRIMARY=
# TENANT_UUID_BOUND_TO_INSTALLATION=
