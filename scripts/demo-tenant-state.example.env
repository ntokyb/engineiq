# Operator-local demo tenant credentials — NEVER commit real keys.
#
# Copy this file to: scripts/demo-tenant-state.local.env
# That path is gitignored. Paste tenant_id + api_key from each
# POST /api/v1/onboarding/register response (or run register-internal-demo-tenants.sh).
#
# ENGINEIQ_API_URL=https://api.engineiq.co.za

# TENANT_MYBILLABLE=
# API_KEY_MYBILLABLE=

# TENANT_THERECORD=
# API_KEY_THERECORD=

# TENANT_SKILLBAY=
# API_KEY_SKILLBAY=

# TENANT_WARROOM=
# API_KEY_WARROOM=

# --- Single-install sanity (internal use only) ---
# GitHub enforces one EngineIQ linkage per installation_id (unique in DB).
# INSTALLATION_ID_NTOKYB_OR_PRIMARY=
# TENANT_UUID_BOUND_TO_INSTALLATION=
