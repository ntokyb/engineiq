# =============================================================================
# EngineIQ — production / Hetzner (docker compose + deploy.sh)
# Copy to .env and replace placeholders. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Compose profiles
# -----------------------------------------------------------------------------
# deploy.sh runs: docker compose --profile platform up -d
# Local dependencies only: docker compose up -d  (postgres + redis + rabbitmq)

# -----------------------------------------------------------------------------
# Docker images (private registry)
# -----------------------------------------------------------------------------
# Registry prefix for all service images, without trailing slash.
# Examples: ghcr.io/your-org/engineiq  |  registry.example.com/engineiq
ENGINEIQ_REGISTRY=ghcr.io/your-org/engineiq
# Image tag (CI should set per release).
ENGINEIQ_TAG=latest
# Set to 1 on the server to build images locally instead of pulling (no registry).
SKIP_PULL=0

# -----------------------------------------------------------------------------
# TLS (Caddy / Let's Encrypt)
# -----------------------------------------------------------------------------
# Email for ACME registration and expiry notices (required by Caddy).
CADDY_ACME_EMAIL=ops@yourcompany.co.za

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=engineiq
# Strong password; used by API, Worker, Admin, Migrator.
POSTGRES_PASSWORD=change-me-long-random-postgres
POSTGRES_DB=engineiq

# -----------------------------------------------------------------------------
# RabbitMQ (not guest/guest — required for container-to-container AMQP)
# -----------------------------------------------------------------------------
RABBITMQ_USER=engineiq
RABBITMQ_PASSWORD=change-me-long-random-rabbitmq
# Optional overrides (defaults match appsettings):
# RABBITMQ_QUEUE_NAME=pr-review-jobs
# RABBITMQ_DLQ_NAME=pr-review-jobs-dlq

# -----------------------------------------------------------------------------
# Redis (data/cache — reserved for future EngineIQ features; no API env yet)
# -----------------------------------------------------------------------------
# No variables required; persistence enabled via Docker volume.

# -----------------------------------------------------------------------------
# GitHub App (API + Worker)
# -----------------------------------------------------------------------------
# Numeric App ID from https://github.com/settings/apps/<your-app>
GITHUB_APP_ID=123456
# App slug (subdomain), e.g. "engineiq" for https://github.com/apps/engineiq
GITHUB_APP_SLUG=your-app-slug
# Full PEM including BEGIN/END lines. In .env use quoted multiline or replace
# newlines with \n in a single line.
GITHUB_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----
...paste key...
-----END RSA PRIVATE KEY-----"
# Webhook secret from the GitHub App settings (HMAC validation).
GITHUB_WEBHOOK_SECRET=hex-or-random-secret

# -----------------------------------------------------------------------------
# Anthropic (Worker only — PR review)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional cost telemetry (ZAR):
# ANTHROPIC_USD_TO_ZAR=18.5
# ANTHROPIC_INPUT_USD_PER_MTOK=3
# ANTHROPIC_OUTPUT_USD_PER_MTOK=15

# -----------------------------------------------------------------------------
# SendGrid (API — onboarding / transactional email)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@engineiq.co.za
SENDGRID_FROM_NAME=EngineIQ
# Optional SendGrid dynamic template IDs (empty if not used):
# SENDGRID_TEMPLATE_WELCOME=d-...
# SENDGRID_TEMPLATE_LIVE_CONFIRMATION=d-...
# SENDGRID_TEMPLATE_THIRTY_DAY_REPORT=d-...

# -----------------------------------------------------------------------------
# Trust / disclosure (API + Worker — PR footer link, GET /security, welcome email DPA URL)
# -----------------------------------------------------------------------------
# TRUST_PUBLIC_API_BASE_URL=https://api.engineiq.co.za
# TRUST_DATA_LOCATION=Hetzner SA / Johannesburg
# TRUST_DPA_PDF_URL=https://engineiq.co.za/legal/dpa.pdf
# TRUST_AI_PROVIDER=Anthropic

# -----------------------------------------------------------------------------
# App URLs (onboarding redirects, CORS is fixed in compose for prod domains)
# -----------------------------------------------------------------------------
# Public portal URL after GitHub App install (used in emails / callbacks).
ENGINEIQ_DASHBOARD_BASE_URL=https://app.engineiq.co.za
# Baked into static marketing + portal at image build time:
NEXT_PUBLIC_ENGINEIQ_API_URL=https://api.engineiq.co.za
NEXT_PUBLIC_PORTAL_URL=https://app.engineiq.co.za

# -----------------------------------------------------------------------------
# Internal admin (Razor UI — Basic auth, bound to 127.0.0.1:8081 on host)
# -----------------------------------------------------------------------------
ENGINEIQ_ADMIN_USERNAME=engineiq-admin
ENGINEIQ_ADMIN_PASSWORD=change-me-long-random-admin

# -----------------------------------------------------------------------------
# deploy.sh — optional Slack webhook (JSON POST, incoming webhook URL)
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX
# After DNS + TLS propagate, public check (set to skip if not ready):
# PUBLIC_API_HEALTH_URL=https://api.engineiq.co.za/health
# SKIP_PUBLIC_HEALTH=0

# -----------------------------------------------------------------------------
# GitHub App webhook URL (configure in GitHub; not read by compose)
# -----------------------------------------------------------------------------
# https://api.engineiq.co.za/webhooks/github
